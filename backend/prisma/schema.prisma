// ─────────────────────────────────────────────────────────────
//  Schéma Prisma — Suivi de production ECODEKO
//
//  DÉVELOPPEMENT  : SQLite (aucune installation requise).
//  PRODUCTION     : pour PostgreSQL, remplacer provider = "sqlite"
//                   par provider = "postgresql" ci-dessous, puis
//                   `npx prisma migrate dev`. DATABASE_URL pointe vers
//                   le fichier SQLite (dev) ou le serveur Postgres (prod).
//
//  NB : Prisma ne supporte pas les `enum` sous SQLite. Les champs
//  `role` et `statut` sont donc des String validées côté serveur
//  (voir src/constants.js). Cela garde le code identique dev/prod.
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               Int      @id @default(autoincrement())
  email            String   @unique
  password         String
  nom              String
  role             String   @default("OPERATEUR") // ADMIN | OPERATEUR | COMPTABLE
  actif            Boolean  @default(true)         // compte désactivable par un ADMIN
  accesFacturation Boolean  @default(false) // accès au module facturation en plus du rôle
  createdAt        DateTime @default(now())

  commandesModifiees Commande[] @relation("ModifiePar")
  logs               Log[]
  releves            Releve[]
}

model Commande {
  id            Int       @id @default(autoincrement())
  reference     String    @unique
  client        String
  designation   String // visuel / nom de fichier principal
  quantite      Int       @default(0)
  statut        String    @default("En attente") // voir STATUTS dans constants.js
  dateCommande  DateTime?
  dateLivraison DateTime? // date de sortie parsée
  dateExpedition DateTime?
  notes         String?

  // ── Colonnes métier conservées depuis la Google Sheet ──
  typeMug         String?
  prixEsat        Float?
  prixVente       Float? // prix de vente unitaire (marge) — réservé ADMIN
  atelier         String? // LETTRAGE / CONDITIONNEMENT
  rebut           Int      @default(0)
  noteTransport   String? // CHRONO, recup alex…
  aFacturer       String? // dates d'arrêt de facturation
  dateSortieTexte String? // date de sortie en texte libre (ASAP, URGENT…)

  // ── Suppression automatique des fichiers à l'expédition ──
  fichiersSupprimes   Boolean   @default(false)
  fichiersSupprimesAt DateTime?

  // ── Première ouverture : null = jamais ouverte (surlignée dans le tableau) ──
  ouverteAt DateTime?

  // ── Facturation ESAT : rattachement à un relevé (null = à facturer) ──
  releve    Releve?   @relation(fields: [releveId], references: [id])
  releveId  Int?
  factureAt DateTime? // date du marquage « facturée » (avec ou sans relevé)

  // ── Soft delete (réservé ADMIN) ──
  supprime   Boolean   @default(false)
  supprimeAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  modifiePar   User? @relation("ModifiePar", fields: [modifieParId], references: [id])
  modifieParId Int?

  fichiers Fichier[]
  logs     Log[]
  lignes   LigneCommande[]

  @@index([statut])
  @@index([client])
  @@index([supprime])
}

// Lignes de détail d'une commande (un visuel / type de mug par ligne).
model LigneCommande {
  id          Int      @id @default(autoincrement())
  commande    Commande @relation(fields: [commandeId], references: [id], onDelete: Cascade)
  commandeId  Int
  typeMug     String?
  visuel      String? // nom du visuel / fichier
  quantite    Int      @default(0)
  commentaire String?
  lien        String? // lien de transfert (WeTransfer / Smash) pour gros fichiers
  ordre       Int      @default(0)

  fichiers Fichier[]

  @@index([commandeId])
}

model Fichier {
  id          Int      @id @default(autoincrement())
  nom         String // nom d'origine
  nomStockage String // nom du fichier stocké
  chemin      String // clé de stockage (chemin relatif disque OU pathname Blob)
  url         String? // URL publique (Vercel Blob) ; null en stockage disque
  taille      Int
  type        String // type MIME
  categorie   String   @default("VISUEL") // VISUEL (purgé après expédition) | DOCUMENT (conservé)
  createdAt   DateTime @default(now())

  commande   Commande @relation(fields: [commandeId], references: [id], onDelete: Cascade)
  commandeId Int

  // Rattachement optionnel à une ligne précise (sinon visuel "commande").
  ligne   LigneCommande? @relation(fields: [ligneId], references: [id], onDelete: Cascade)
  ligneId Int?

  @@index([commandeId])
  @@index([ligneId])
}

// Catalogue des produits (types de mug) géré par l'administrateur.
model Produit {
  id         Int      @id @default(autoincrement())
  nom        String   @unique
  prixAchat  Float? // prix d'achat unitaire
  image      String? // clé de stockage de la miniature
  imageUrl   String? // URL publique (Vercel Blob) ; null en stockage disque
  actif      Boolean  @default(true)
  compteMugs Boolean  @default(true) // false = accessoire (étiquette…) non compté dans la quantité de mugs
  createdAt  DateTime @default(now())
}

// Relevé de facturation ESAT : groupe de commandes facturées ensemble.
// detailJson fige les lignes (réf, client, qté, prix, montant) au moment
// de la création, pour que le relevé reste exact même si une commande change.
model Releve {
  id         Int      @id @default(autoincrement())
  numero     String   @unique // ex : REL-2026-001
  libelle    String? // ex : « Juin 2026 »
  total      Float    @default(0)
  detailJson String? // lignes figées (JSON)
  createdAt  DateTime @default(now())

  creePar   User? @relation(fields: [creeParId], references: [id])
  creeParId Int?

  commandes Commande[]
}

// Réglages de production par visuel (température, temps de presse, note).
// La clé `cle` est le visuel normalisé (majuscules, espaces réduits) pour
// retrouver le réglage même si l'orthographe varie légèrement.
model Reglage {
  id            Int      @id @default(autoincrement())
  cle           String   @unique // visuel normalisé (clé de correspondance)
  visuel        String            // libellé affiché (dernière saisie)
  temperature   Int? // °C
  tempsSecondes Int? // temps de presse en secondes
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Log {
  id        Int      @id @default(autoincrement())
  action    String
  detail    String?
  createdAt DateTime @default(now())

  user   User? @relation(fields: [userId], references: [id])
  userId Int?

  commande   Commande? @relation(fields: [commandeId], references: [id], onDelete: Cascade)
  commandeId Int?

  @@index([commandeId])
}
