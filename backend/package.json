{
  "name": "production-tracker-backend",
  "version": "1.0.0",
  "description": "API de suivi de production (ECODEKO) — Express + Prisma + JWT",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "start:preview": "NODE_ENV=production PORT=4100 node src/server.js",
    "dev": "node --watch src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:generate:pg": "prisma generate --schema prisma/schema.postgres.prisma",
    "prisma:push:pg": "prisma db push --schema prisma/schema.postgres.prisma",
    "prisma:push": "prisma db push",
    "seed": "node scripts/seed-admin.js",
    "import": "node scripts/import-csv.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "@vercel/blob": "^2.4.1",
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.1"
  },
  "devDependencies": {
    "prisma": "^6.2.1"
  }
}
