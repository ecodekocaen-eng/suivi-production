# ─────────────────────────────────────────────────────────────
#  Backend — configuration. Copier en ".env" et adapter.
# ─────────────────────────────────────────────────────────────

# Connexion base de données.
#  Le chemin "file:" est résolu PAR RAPPORT au dossier prisma/.
#  - DEV (SQLite)        : file:./dev.db   → crée backend/prisma/dev.db
#  - PROD (PostgreSQL)   : postgresql://user:pass@host:5432/suivi
#    (penser à mettre provider = "postgresql" dans prisma/schema.prisma)
DATABASE_URL="file:./dev.db"

# Port d'écoute de l'API
PORT=4000

# Environnement : development | production
NODE_ENV=development

# Secret de signature des JWT (générer une longue chaîne aléatoire) :
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=changez-moi-par-une-longue-chaine-aleatoire
JWT_EXPIRES_IN=8h

# Origine autorisée pour CORS (URL du frontend)
CORS_ORIGIN=http://localhost:5173

# Pilote de stockage des fichiers :
#   disk  → système de fichiers local (dev / VPS / Docker)
#   blob  → Vercel Blob (déploiement Vercel ; voir DEPLOY-VERCEL.md)
STORAGE_DRIVER=disk

# (disk uniquement) dossier des fichiers — disque persistant en production
UPLOAD_DIR=./uploads

# (blob uniquement) jeton injecté automatiquement par Vercel quand un store
# Blob est connecté au projet. En local on n'en a pas besoin (driver disk).
# BLOB_READ_WRITE_TOKEN=

# Taille maximale par fichier (octets).
#   - disk/VPS : 10 Mo (10485760)
#   - Vercel   : 4 Mo (4194304) — au-delà, utiliser le lien WeTransfer/Smash
MAX_FILE_SIZE=10485760

# Cookie sécurisé (true si servi en HTTPS)
SECURE_COOKIE=false
